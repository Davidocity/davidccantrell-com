---
import { plainify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
  columns?: 2 | 3;
};

const { className = "", posts, columns = 2 } = Astro.props;
---

<div class={`archive-grid ${columns === 3 ? "archive-grid-3" : "archive-grid-2"} ${className}`}>
  {
    posts.map((post) => (
      <article class="archive-card">
      {post.data.image && (
        <a href={`/blog/${post.id}`} class="block overflow-hidden group">
          <Image
            class="group-hover:scale-[1.03] transition duration-300 w-full"
            src={post.data.image}
            alt={post.data.title}
            width={445}
            height={230}
          />
        </a>
      )}

      <div class="archive-card-content">
        <h3 class="archive-title mb-2">
          <a
            href={`/blog/${post.id}`}
            class="block hover:text-primary transition duration-300"
          >
            {post.data.title}
          </a>
        </h3>

        <p class="text-text line-clamp-2">
          {post.data.description || plainify(post.body ?? "")}
        </p>
      </div>
      </article>
    ))
  }
</div>